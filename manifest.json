{
  "manifest_version": 3,
  "name": "AI Assistant",
  "version": "1.5.0",
  "description": "多端AI调度工具，支持Yuanbao和Gemini",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup/main/main.html",
    "default_title": "AI Assistant"
  },
  "options_ui": {
    "page": "/options/options.html",
    "open_in_tab": true
},
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "notifications",
    "commands",
    "downloads",
    "alarms",
    "clipboardRead",
    "history",
    "contextMenus",
    "bookmarks"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "execute_div_copy": {
      "suggested_key": { "default": "Alt+C" },
      "description": "执行 div Copy 脚本"
    },
    "imgs_picker": {
      "suggested_key": { "default": "Alt+D" },
      "description": "执行 div Copy 脚本"
    },
    "copy_file": {
      "suggested_key": { "default": "Alt+F" },
      "description": "获得剪切板内容保存为文件"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "runjs/tripleSpace/tripleSpace.js",
        "runjs/goto/goto.js",
        "runjs/word/word.js",
        "runjs/translation/lib/marked.min.js",
        "runjs/translation/lib/katex.min.js",
        "runjs/translation/content.js",
        "runjs/translation/content-ocr.js"
      ],
      "css": [
        "runjs/tripleSpace/tripleSpace.css",
        "runjs/translation/content.css",
        "runjs/translation/content-ocr.css",
        "runjs/translation/lib/katex.min.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": ["runjs/bilibiliCleaner/bilibiliCleaner.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "contentScripts/*.js",
        "funcs/*.js",
        "funcs/**/*.js",
        "runjs/*.js",
        "runjs/**/*.js",
        "runjs/**/*.css",
        "modules/translation/**/*.js",
        "modules/translation/**/*.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
